<Style name="cycleways">
  <Rule>
    &maxscale_zoom13;
    &minscale_zoom15;
    <Filter>[highway] = 'cycleway' or ([highway] = 'path' and [bicycle] = 'designated')</Filter>
    <LineSymbolizer stroke="#ffffff" stroke-linecap="round" stroke-linejoin="round" stroke-opacity="0.4" stroke-width="3" />
    <LineSymbolizer stroke="#0000ff" stroke-dasharray="1, 3" stroke-linecap="round" stroke-linejoin="round" stroke-width="1" />
  </Rule>
  
  <Rule>
    &maxscale_zoom16;
    &minscale_zoom18;
    <Filter>[highway] = 'cycleway' or ([highway] = 'path' and [bicycle] = 'designated')</Filter>
    <LineSymbolizer stroke="#ffffff" stroke-linecap="round" stroke-linejoin="round" stroke-opacity="0.4" stroke-width="4.5" />
    <LineSymbolizer stroke="#0000ff" stroke-dasharray="2, 4" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" />
  </Rule>
</Style>
